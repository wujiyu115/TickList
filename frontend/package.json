    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.14.182",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.33",
    "@types/react-dom": "^18.0.11",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "@vitest/ui": "^4.1.4",
    "eslint": "^8.12.0",
    "jsdom": "^29.0.2",
    "less": "^3.13.1",
    "msw": "^2.13.3",
    "playwright": "^1.61.1",
