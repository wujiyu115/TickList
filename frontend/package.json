    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "antd": "^5.0.0",
    "axios": "^1.6.0",
    "classnames": "^2.3.1",
    "core-js": "^3.45.1",
    "dayjs": "^1.11.20",
    "lowlight": "^3.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.10.0",
    "tiptap-markdown": "^0.9.0"
