{
  "name": "ticklist-frontend",
  "description": "TickList Todo Management Frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "bun run dev",
    "dev": "rsbuild dev",
    "build": "rsbuild build",
    "build:dev": "NODE_ENV=development rsbuild build",
    "build:mobile": "rsbuild build",
    "cap:sync": "npx cap sync",
    "cap:ios": "rsbuild build && npx cap sync ios && npx cap open ios",
    "cap:android": "rsbuild build && npx cap sync android && npx cap open android",
    "preview": "rsbuild preview",
    "shot": "node scripts/shot.mjs",
    "lint": "eslint --ext .js,.ts,.tsx .",
    "lint-fix": "eslint --ext .js,.ts,.tsx --fix .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest --run"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.7",
    "@capacitor/android": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/ios": "^8.3.3",
    "@capacitor/local-notifications": "^8.1.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@tiptap/extension-code-block-lowlight": "^3.27.1",
    "@tiptap/extension-color": "^3.27.1",
    "@tiptap/extension-highlight": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-table-cell": "^3.27.1",
    "@tiptap/extension-table-header": "^3.27.1",
