environment: development

jwt:
  secret_key: "ticklist-secret-key-change-in-production"
  algorithm: "HS256"
  access_token_expire_hours: 12

database:
  connect_string: "sqlite:///ticklist.db"
  # 连接字符串示例:
  # SQLite: sqlite:///ticklist.db
  # MySQL: mysql+pymysql://username:password@host:port/database?charset=utf8mb4

auth:
  register_enabled: true  # 设为 false 关闭注册，可通过环境变量 REGISTER_ENABLED 覆盖
  admin_username: ""  # 指定管理员用户名，该用户注册时自动成为管理员，可通过环境变量 ADMIN_USERNAME 覆盖

cors:
  allowed_origins:
    - "http://localhost:5000"
    - "http://127.0.0.1:5000"

webauthn:
  rp_id: "localhost"
  rp_name: "TickList"
  origin: "http://localhost:5000"

logging:
  level: INFO
  console_level: INFO
  file_level: INFO
  error_level: ERROR
  log_dir: "logs"

ai:
  provider: claude  # claude or openai, via env AI_PROVIDER
  api_key: ""  # Set via env AI_API_KEY
  model: claude-sonnet-4-5-20250514
  max_tokens: 4096
  openai_api_key: ""  # Set via env OPENAI_API_KEY
  openai_model: gpt-4o  # Set via env OPENAI_MODEL
  openai_base_url: ""  # Set via env OPENAI_BASE_URL (for compatible APIs)
  # 用户数据快照在 system prompt 中的格式：
  #   json - 自描述、稳定（默认基线）
  #   toon - Token-Oriented Object Notation，对同构数组用「表头+CSV行」节省 30-55% token
  # 可通过环境变量 AI_SYSTEM_PROMPT_FORMAT 覆盖
  system_prompt_format: json
  tools_call_timeout: 60  # L3 tools_call 层 SDK 超时秒数（默认 60，可通过 AI_TOOLS_CALL_TIMEOUT 覆盖）
  # AI Pipeline 灰度配置（详见 docs/superpowers/specs/2026-04-27-ai-hybrid-pipeline-design.md）
  pipeline:
    enabled: false                  # 总开关：false=走 legacy tools_call；true=启用三层 pipeline
    enable_rule_layer: true         # 是否启用规则层：false=跳过规则层，直接进入 JSON Mode 层
    enable_json_mode_layer: true    # 是否启用 JSON Mode 层：false=规则未命中时直接降级到 tools_call
    json_mode_timeout: 15           # L2 JSON Mode 层的 LLM 调用超时秒数（默认 15，可通过 AI_PIPELINE_JSON_MODE_TIMEOUT 覆盖）
