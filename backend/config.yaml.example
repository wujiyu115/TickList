environment: development

jwt:
  secret_key: "ticklist-secret-key-change-in-production"
  algorithm: "HS256"
  access_token_expire_hours: 24

database:
  type: "sqlite"          # sqlite / mysql
  # SQLite 配置
  sqlite_path: "ticklist.db"
  # MySQL 配置
  mysql_host: "localhost"
  mysql_port: 3306
  mysql_database: "ticklist"
  mysql_username: ""
  mysql_password: ""

cors:
  allowed_origins:
    - "http://localhost:3000"
    - "http://127.0.0.1:3000"
    - "http://localhost:5000"
    - "http://127.0.0.1:5000"

logging:
  level: INFO
  console_level: INFO
  file_level: INFO
  error_level: ERROR
  log_dir: "logs"
